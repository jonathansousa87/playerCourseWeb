# Banco local (Docker Compose — desenvolvimento offline)
DATABASE_URL_LOCAL=postgres://playercourse:playercourse_dev@localhost:5433/playercourse

# Supabase (producao)
SUPABASE_DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
SUPABASE_URL=https://[PROJECT-REF].supabase.co
# Backend usa secret key (bypassa RLS — service_role)
SUPABASE_SERVICE_KEY=sb_secret_...
# Anon/publishable key (publica) — usada pelo backend pra validar JWTs e
# repassada ao frontend via VITE_SUPABASE_ANON_KEY
SUPABASE_ANON_KEY=sb_publishable_...

# Banco ativo — troque para DATABASE_URL_LOCAL pra dev offline
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

PORT=3001
COURSES_PATH=/caminho/para/seus/cursos/

# Cliente frontend (CORS + Vite expoe variaveis VITE_* no bundle)
CLIENT_ORIGIN=http://localhost:5173
VITE_SUPABASE_URL=https://[PROJECT-REF].supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# Geracao de materiais com IA
DEEPSEEK_API_KEY=
GROQ_API_KEY=
# DeepSeek nao publica rate limit fixo; o cliente paraleliza com teto e re-tenta
# em 429/503/timeout. Ajuste se quiser mais/menos agressivo:
DEEPSEEK_CONCURRENCY=4
DEEPSEEK_MAX_RETRIES=5

# WhisperX — transcreve aulas sem .txt no "Gerar curso de leitura".
# WHISPERX_BIN: comando-base do whisperx (a plataforma adiciona as flags fixas,
# iguais ao DubAI). Pode ser conda ou docker:
#   WHISPERX_BIN=/home/USER/miniconda3/envs/whisperx/bin/whisperx
#   WHISPERX_BIN=docker exec whisperx-container whisperx
# (No modo docker, monte a pasta de cursos no container para o audio ser visivel.)
WHISPERX_BIN=
# cuda | cpu — vazio = auto-detecta via nvidia-smi
WHISPERX_DEVICE=
# PT-BR: large-v3-turbo (multilingue). distil-large-v3.5 e English-only.
WHISPERX_MODEL=large-v3-turbo
WHISPERX_LANGUAGE=pt
# So no modo conda, se precisar apontar libs CUDA extras manualmente:
WHISPERX_LD_LIBRARY_PATH=

# Pre-condensacao local (opcional) das transcricoes ANTES do DeepSeek.
# Um modelo local barato (llama-server OpenAI-compatible) limpa a fala por aula
# — muletas, narracao de digitacao — preservando o tecnico, sem modernizar nem
# traduzir. Corta ~50-60% do input que vai pro DeepSeek (a etapa cara). Off por
# default; se o servidor estiver fora, DEGRADA gracioso (usa a transcricao
# original e loga o aviso). Suba o llama-server separadamente e SO depois do
# WhisperX terminar (ambos disputam a VRAM).
PRECONDENSE_ENABLED=false
PRECONDENSE_URL=http://127.0.0.1:8080/v1/chat/completions
PRECONDENSE_MODEL=local
PRECONDENSE_MAX_TOKENS=4096
PRECONDENSE_TEMPERATURE=0.1
# Transcricoes abaixo de N chars nao sao pre-condensadas (nao compensa):
PRECONDENSE_MIN_CHARS=400
PRECONDENSE_TIMEOUT_MS=300000

# Kokoro TTS — usado no "Gerar IA > Podcast". E um SERVIDOR HTTP (porta 8880).
# A plataforma so fala com ele pela URL; quem decide GPU vs CPU e o PROPRIO
# Kokoro (pela imagem/instalacao que voce sobe), nao a plataforma.
#
# KOKORO_URL: onde o Kokoro responde (pode ser outra maquina/host).
KOKORO_URL=http://127.0.0.1:8880
# KOKORO_START_CMD: como subir o Kokoro se estiver fora do ar (a plataforma roda
# isso e espera o /v1/audio/voices responder). Deixe VAZIO se voce mesmo sobe.
# Exemplos por cenario:
#   docker (GPU):  docker start kokoro-container
#   docker (GPU/CPU via compose): docker compose -f /caminho/kokoro-install/docker-compose.yml up -d
#   docker (CPU):  docker run -d --name kokoro-cpu -p 8880:8880 ghcr.io/remsky/kokoro-fastapi-cpu:latest
#   miniconda/pip: bash -lc "conda run -n kokoro python -m kokoro_fastapi"  (ajuste ao seu setup)
#   subo manualmente: (deixe vazio)
KOKORO_START_CMD=docker start kokoro-container
# Vozes do podcast (codigos do Kokoro; aceita BLEND com "+"). pf_dora = unica
# feminina PT-BR; pm_santa = masculina grave PT-BR. O "+es" mistura a versao em
# espanhol pra deixar mais natural (mesma estrategia do preset top do DubAI).
PODCAST_VOICE_SENIOR=pm_santa+bm_daniel+im_nicola
PODCAST_VOICE_JUNIOR=pf_dora+bf_lily+if_sara
# Nomes dos personagens do podcast (senior fala, junior entrevista):
PODCAST_NAME_SENIOR=Luiz
PODCAST_NAME_JUNIOR=Daniela

# WhisperX modelo pra cursos em INGLES no "Gerar curso de leitura" (a leitura
# final continua saindo em PT-BR). English-only, rapido.
WHISPERX_MODEL_EN=distil-large-v3.5

# Config do cliente (src/config.js). Ambos opcionais.
# VITE_API_BASE: deixe vazio para usar caminhos relativos (proxy do Vite em dev,
# mesma origem em producao). Defina so se o backend estiver em outro host/porta.
VITE_API_BASE=
# VITE_COURSES_PATH: fallback inicial do caminho de cursos no UI (o valor real
# vem do backend via /api/config/courses-path).
VITE_COURSES_PATH=
